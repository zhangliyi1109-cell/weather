# -----------------------------------------------------------------------------
# 本地/服务器环境变量模板：复制为 .env 后按需填写
#   cp .env.example .env
# 不要将含密钥的 .env 提交到 Git（已在 .gitignore）
# Railway：在 Project → Variables 中填入同名变量（勿勾选泄露日志）
# -----------------------------------------------------------------------------

# --- 飞书（勿提交密钥到仓库）---
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_TABLE_ID=

# --- Flask ---
# Session 加密密钥：生产务必使用长随机串；留空则使用代码内开发默认值
# 生成示例：python3 -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY=

SERVER_HOST=0.0.0.0
SERVER_PORT=5002
# 生产建议 false
FLASK_DEBUG=false

# --- 业务开关 ---
# true：拉观远 BI；false：无 BI 时走空数据/本地快照策略
USE_BI_DATA=true

# --- 观远多数据源映射（推荐）---
# JSON 路径（相对项目根目录）；定义「逻辑数据源名 → 页面 pgId + 卡片 cdId」
# 详见 guandata_sources.json / guandata_sources.example.json
GUANDATA_SOURCES_FILE=guandata_sources.json

# --- 观远 Public API（与 guandata.py 一致；密钥勿提交仓库）---
GUANDATA_BASE_URL=https://bi.marius.vip
# 应用 Token（走 loginId/sign-in 时必填其一组合）
GUANDATA_APP_TOKEN=
GUANDATA_LOGIN_ID=
# 若已有可直接调接口的会话 Token，可只设此项，跳过 sign-in
GUANDATA_X_AUTH_TOKEN=

# 以下三项为「未使用 guandata_sources.json 或未配置 inventory 字段时」的回退
# 页面 ID：浏览器地址 .../page/ 后一段
GUANDATA_PAGE_ID=x340e4c117103479ebe5d1e5
# 卡片 cdId：留空则按名称关键字或卡片类型自动选卡（python guandata.py cards <页面ID> 查看）
GUANDATA_CARD_ID=
# 自动选卡时：卡片名称包含该关键字则优先（JSON 里可置 "" 表示不按名称匹配）
GUANDATA_CARD_NAME_KEYWORD=拉新

# 观远 HTTP 超时（秒）
GUANDATA_REQUEST_TIMEOUT=120

# --- 其它数据（占位，当前推荐逻辑未读取）---
# SALES_DATA_MODE=file
# SALES_DATA_CSV_PATH=
# SALES_DATA_API_BASE_URL=
# SALES_DATA_API_KEY=
