# -----------------------------------------------------------------------------
# 本地/服务器环境变量模板：复制为 .env 后按需填写
#   cp .env.example .env
# 不要将含密钥的 .env 提交到 Git（已在 .gitignore）
# 生产/服务器：在环境变量或 .env 中填入同名变量（勿提交含密钥的 .env）
# -----------------------------------------------------------------------------

# --- 飞书（勿提交密钥到仓库）---
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_TABLE_ID=

# --- Flask ---
# Session 加密密钥：生产务必使用长随机串；留空则使用代码内开发默认值
# 生成示例：python3 -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY=
# 误填为 PP_SECRET_KEY 时也会被读取（与 APP_SECRET_KEY 二选一即可）

# --- 登录账号（二选一或同时用：JSON 合并后 APP_USERS_JSON 会覆盖同名用户）---
# 用户文件路径（相对项目根目录或绝对路径），默认 app_users.json；见 app_users.example.json
# APP_USERS_FILE=app_users.json
# 阿里云 / 容器可在控制台填一整段 JSON（无则仅读文件；两者皆无则回退内置开发账号并打日志警告）
# APP_USERS_JSON={"admin":{"password":"强密码","role":"admin"},"viewer":{"password":"强密码","role":"user"}}

SERVER_HOST=0.0.0.0
SERVER_PORT=5002
# 生产建议 false
FLASK_DEBUG=false

# --- 业务开关 ---
# true：拉观远 BI；false：无 BI 时走空数据/本地快照策略
USE_BI_DATA=true

# 利润款：款式成本/售价 JSON（默认项目根 sku_unit_cost.json，见 sku_unit_cost.example.json）
# SKU_UNIT_COST_FILE=sku_unit_cost.json
# 引流/利润/库存款门槛：请在 recommendation_rules.json → product_role_thresholds 配置
# （或管理员登录后在「配置页面」单品角色门槛表单中修改）

# --- 观远多数据源映射（推荐）---
# JSON 路径（相对项目根目录）；定义「逻辑数据源名 → 页面 pgId + 卡片 cdId」
# 详见 guandata_sources.json / guandata_sources.example.json
GUANDATA_SOURCES_FILE=guandata_sources.json
# 拉新明细表中「价格定位」维度列下标（从 0 起，默认 8）
# GUANDATA_DIM_PRICE_POSITION_INDEX=8

# --- 观远 Public API（与 guandata.py 一致；密钥勿提交仓库）---
GUANDATA_BASE_URL=https://bi.marius.vip
# 必填（否则只能靠下方 X_AUTH_TOKEN，过期即 401）：sign-in 自动换 X-Auth-Token
# 切勿添加「空字符串」的 GUANDATA_APP_TOKEN，否则会禁用代码侧 sign-in。
GUANDATA_APP_TOKEN=
GUANDATA_LOGIN_ID=
# 可选：手动会话 Token（会过期）。配置了 APP_TOKEN+LOGIN_ID 时将优先 sign-in，不再依赖此项
GUANDATA_X_AUTH_TOKEN=
# 设为 true 时强制只用 GUANDATA_X_AUTH_TOKEN（不 sign-in，无法自动续期）
# GUANDATA_ONLY_ENV_X_AUTH_TOKEN=false
# Token 缓存路径（默认系统临时目录下 guandata_token_cache.json）
# GUANDATA_TOKEN_CACHE_PATH=
# GUANDATA_RUNTIME_DIR=

# 以下三项为「未使用 guandata_sources.json 或未配置 inventory 字段时」的回退
# 页面 ID：浏览器地址 .../page/ 后一段
GUANDATA_PAGE_ID=x340e4c117103479ebe5d1e5
# 卡片 cdId：留空则按名称关键字或卡片类型自动选卡（python guandata.py cards <页面ID> 查看）
GUANDATA_CARD_ID=
# 自动选卡时：合并后的卡片标题包含该关键字则优先（多个用英文逗号，命中任一即可；JSON 可置 "" 禁用按名匹配）
GUANDATA_CARD_NAME_KEYWORD=拉新
# 卡片取数 view，逗号分隔依次尝试（默认 GRAPH,TABLE,LIST,DETAIL,GRID）；单一视图示例：TABLE
# GUANDATA_CARD_VIEW=

# 观远 HTTP 超时（秒）
GUANDATA_REQUEST_TIMEOUT=120

# --- 其它数据（占位，当前推荐逻辑未读取）---
# SALES_DATA_MODE=file
# SALES_DATA_CSV_PATH=
# SALES_DATA_API_BASE_URL=
# SALES_DATA_API_KEY=
